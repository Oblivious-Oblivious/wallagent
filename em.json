{
  "$schema": "https://raw.githubusercontent.com/Oblivious-Oblivious/Emeralds/master/schema/em.schema.json",
  "author": "atha",
  "name": "wallagent",
  "version": "0.0.1",
  "license": "mit",
  "locignore": {
    "directories": ["libs"]
  },
  "lintignore": {
    "directories": ["libs"]
  },
  "scripts": {},
  "compile-flags": {
    "darwin": {
      "debug": [
        "clang",
        "-O2",
        "-std=c89",
        "-g",
        "-fsanitize=address",
        "-lcurl",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-pedantic",
        "-pedantic-errors",
        "-Wpedantic"
      ],
      "release": ["clang", "-O2", "-std=c89", "-lcurl"]
    },
    "linux": {
      "debug": [
        "gcc",
        "-O2",
        "-std=c89",
        "-g",
        "-lcurl",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-pedantic",
        "-pedantic-errors",
        "-Wpedantic"
      ],
      "release": ["gcc", "-O2", "-std=c89", "-lcurl"]
    },
    "win32": {
      "debug": [
        "gcc",
        "-O2",
        "-std=c89",
        "-g",
        "-lcurl",
        "-Wall",
        "-Wextra",
        "-Werror",
        "-pedantic",
        "-pedantic-errors",
        "-Wpedantic"
      ],
      "release": ["gcc", "-O2", "-std=c89", "-lcurl"]
    }
  },
  "dependencies": {},
  "dev-dependencies": {
    "cSpec": "Oblivious-Oblivious/cSpec"
  }
}
